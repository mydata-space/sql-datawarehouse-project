-- =========================================================
-- Quality Check : gold dimension products
-- =========================================================

-- Check duplicates
-- Expected result : no duplicates 
SELECT prd_key, COUNT(*) AS flag_duplicates
FROM (
SELECT
    pr.prd_id,
    pr.cat_id,
    pr.prd_key,
    pr.prd_nm,
    pr.prd_cost,
    pr.prd_line,
    pr.prd_start_dt,
    pr.prd_end_dt,
    pc.cat,
    pc.subcat,
    pc.maintenance
FROM silver.crm_prd_info pr
LEFT JOIN silver.erp_px_cat_gv2 pc ON pr.cat_id = pc.id
WHERE pr.prd_end_dt IS NULL) DD
GROUP BY prd_key
HAVING COUNT(*) > 1; 

