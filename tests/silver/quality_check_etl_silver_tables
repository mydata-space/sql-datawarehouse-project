/*
==============================================================
Test : Quality Check
==============================================================
Script Purpose:
	This script performs various quality checks for data consistency, accuracy,
	and standardization across the 'silver' schemas. It includes checks for:
	- Null or duplicate primary keys.
	- Unwanted spaces in string fields.
	- Data standardization and consistency.
	- Invalid date ranges and orders.
	- Data consistency between related fields.

Usage Notes:
	- Run these checks after data loading Silver Layer.
	- Investigate and resolve any discrepancies found during the checks.
==============================================================
*/

-- >>  CRM Tables
-- ==============
------------------------------------------------
-- ETL >> table silver.crm_cust_info
------------------------------------------------

-- Check null or duplicates in primary key
-- Expected : No null or duplicates in the primary key
SELECT 
cst_id,COUNT(*) AS flag_duplicates
FROM silver.crm_cust_info
GROUP BY cst_id
HAVING COUNT(*) > 1;

--	Check for unwanted spaces in NVARCHAR column cst_firstname and cst_lastname
--	Expected : no space in the column
SELECT 
cst_firstname,
cst_lastname
FROM silver.crm_cust_info
WHERE  cst_firstname != TRIM(cst_firstname) OR cst_lastname != TRIM(cst_lastname);

--	Standardize and consistency for the columns cst_marital_status and cst_gndr
--	Expected result : No inconsistency 
SELECT 
DISTINCT cst_marital_status,
CASE 
	WHEN cst_marital_status = 'S' THEN 'Single'
	WHEN cst_marital_status = 'M' THEN 'Married'
	ELSE 'n/a'
END
FROM silver.crm_cust_info;

------
SELECT 
DISTINCT cst_gndr,
CASE 
	WHEN cst_gndr = 'F' THEN 'Female'
	WHEN cst_gndr = 'M' THEN 'Male'
	ELSE 'n/a'
END
FROM silver.crm_cust_info;

----------------------------------------------
-- ETL >> table silver.crm_prd_info
----------------------------------------------

-- Check null or duplicates in primary key
-- Expected : No null or duplicates in the primary key
SELECT *
FROM(
SELECT *, 
ROW_NUMBER() OVER(PARTITION BY prd_id ORDER BY prd_start_dt DESC) AS flag_duplicates
FROM silver.crm_prd_info) M WHERE flag_duplicates > 1; 

-- Split column to create foreign key
-- Expected : join crm_prd_info table and erp_px_cat_gv2 table
SELECT 
prd_key,
REPLACE(SUBSTRING(TRIM(prd_key),1,5),'-','_') AS prd_key,
SUBSTRING(TRIM(prd_key),5,LEN(prd_key)) AS prd_category
FROM silver.crm_prd_info; 

--	Check for unwanted spaces in NVARCHAR column prd_nm 
--	Expected : no space in the column
SELECT 
prd_nm
FROM silver.crm_prd_info
WHERE prd_nm != TRIM(prd_nm);

-- Check for null and negative prd_cost
-- Expected : No negative cost and null
SELECT * 
FROM silver.crm_prd_info
WHERE prd_cost < 0 OR  prd_cost IS NULL;

--	Standardize and consistency for the columns prd_line
--	Expected result : No inconsistency 
SELECT 
DISTINCT prd_line,
CASE 
	WHEN prd_line = 'M' THEN 'Mountain'
	WHEN prd_line = 'T' THEN 'Touring'
	WHEN prd_line = 'R' THEN 'Road'
	WHEN prd_line = 'S' THEN 'other sales'
	ELSE 'n/a'
END
FROM silver.crm_prd_info;

-- Check for inconsitency in date columns prd_start_dt, prd_end_dt
SELECT *
FROM silver.crm_prd_info
WHERE prd_start_dt < prd_end_dt  
/*There are inconsistencies End date is inferior to start date. we have decided 
to use the function Lead of the start date - 1 month to fill the end date column */

