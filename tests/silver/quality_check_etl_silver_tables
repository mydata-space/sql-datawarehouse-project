-- Check the existence of primairy key
-- Expected : Not in the table silver.crm_prd_info
SELECT * FROM silver.erp_cust_az12 WHERE 
CASE 
	WHEN cid LIKE 'NAS%' THEN SUBSTRING(cid, 4, LEN(cid))
	ELSE cid 
END NOT IN (SELECT cst_key FROM silver.crm_cust_info)

-- Check for invalid date and convert into date type the columns bdate
-- Expected : bdate < GETDATE() AND Int column LEN 10 digit 
SELECT 
bdate
FROM silver.erp_cust_az12
WHERE  bdate > GETDATE() OR bdate IS NULL OR LEN(bdate) != 10 

--	Standardize and consistency for the columns prd_line
--	Expected result : No inconsistency 
SELECT 
DISTINCT gen,
CASE 
	WHEN TRIM(gen) = 'F' THEN 'Female'
	WHEN TRIM(gen) = 'M' THEN 'Male'
	WHEN TRIM(gen) = 'Female' THEN 'Female'
	WHEN TRIM(gen) = 'Male' THEN 'Male'
	ELSE NULL
END gen
FROM silver.erp_cust_az12
ORDER BY gen; 

